#!/bin/bash
# Build the Elixir release for the Android target and package it as
# rel/android/app/src/main/assets/app.zip so Bridge.kt can extract it on the
# first launch.
#
# Invoked from rel/android/app/build.gradle (Gradle's working directory is
# rel/android/app/) and indirectly from scripts/build_android.sh.
#
# The Elixir source code lives in this repository's root (../../.. from this
# script). No git checkout happens any more; the script always builds the
# parent project as-is.

set -euo pipefail

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$APP_DIR/../../.." && pwd)"
APP_FILE="$APP_DIR/src/main/assets/app.zip"

# Make asdf shims available even when launched from a non-login Gradle
# subprocess that hasn't sourced ~/.asdf/asdf.sh.
if [ -d "$HOME/.asdf/shims" ]; then
    export PATH="$HOME/.asdf/shims:$PATH"
fi

# The embedded Android runtime is ABI-locked to a specific Erlang/OTP release,
# so pin the toolchain to the versions declared in the adjacent .tool-versions
# file. Only do this when asdf is available; users with their own
# Erlang/Elixir/Node on $PATH (e.g. CI using setup-beam) fall through.
if command -v asdf >/dev/null 2>&1 && [ -f "$APP_DIR/.tool-versions" ]; then
    missing_tools=()
    while IFS= read -r line || [ -n "$line" ]; do
        case "$line" in
            ''|\#*) continue ;;
        esac
        tool=${line%% *}
        version=${line#* }
        upper=$(echo "$tool" | tr '[:lower:]' '[:upper:]')
        export "ASDF_${upper}_VERSION=$version"
        if ! asdf where "$tool" "$version" >/dev/null 2>&1; then
            missing_tools+=("$tool")
        fi
    done < "$APP_DIR/.tool-versions"

    if [ ${#missing_tools[@]} -gt 0 ]; then
        echo ">>> One or more pinned Erlang/Elixir/Node versions for the Android" >&2
        echo ">>> wrapper are not installed. Bootstrapping them with 'asdf install'." >&2
        echo ">>> Building Erlang/OTP from source can take 10-30 minutes on first run." >&2

        installed_plugins=$(asdf plugin list 2>/dev/null || true)
        for tool in "${missing_tools[@]}"; do
            if ! printf '%s\n' "$installed_plugins" | grep -qx "$tool"; then
                echo ">>> Adding asdf plugin: $tool" >&2
                asdf plugin add "$tool"
            fi
        done

        (cd "$APP_DIR" && asdf install)
    fi
fi

export MIX_ENV=prod
export MIX_TARGET=android

cd "$PROJECT_ROOT"

mix local.hex --force --if-missing
mix local.rebar --force --if-missing
mix deps.get

if [ ! -d "assets/node_modules" ]; then
    (cd assets && npm install)
fi

rm -f "$APP_FILE"

mix assets.deploy
mix release --overwrite

cd "_build/${MIX_TARGET}_${MIX_ENV}/rel/default_release"
zip -9r "$APP_FILE" lib/ releases/ --exclude "*.so"
